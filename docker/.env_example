# -------- Server (mission_control) --------
WS_HOST=0.0.0.0
WS_PORT=8080
MAX_WS_MB=25
UPLOAD_DIR=/uploads

# Optional output dirs
CHATS_DIR=saved_chats
PROMPTS_DIR=prompts
TELEMETRY_DIR=telemetry
RECORDINGS_DIR=/recordings
PULL_BATCH_SIZE=2
PULL_CHUNK_BYTES=524288

# Model selection
MODEL_BACKEND=gemini
MODEL_NAME=gemini-2.5-flash
# MODEL_BACKEND=openai
# MODEL_NAME=oai-gpt-4o

# API keys (set the one matching MODEL_BACKEND)
GEMINI_AI_KEY=YOUR_GEMINI_KEY
OPEN_AI_KEY=YOUR_OPENAI_KEY

# Prompt/grid-related
FOV_ANGLE=90
FONT_LOCATION=/fonts

# -------- Producer (drone_control) --------
SERVER_URL=ws://YOUR_SERVER_IP_OR_DOMAIN:8080
COMMANDS_DIR=/commands
VIDEO_DIR=/video
VIDEO_DEVICE=/dev/video0

WIDTH=480
HEIGHT=480
QUALITY=90
RECORD_FPS=30

MAV_DEVICE=/dev/ttyAMA0
MAV_BAUD=57600
TELEM_TIMEOUT=2.0
MOVE_METHOD=0
EXECUTE_MOVES=1
